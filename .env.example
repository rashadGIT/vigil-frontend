# Next.js Frontend — Vigil
# Copy to .env.local for local development

# API
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# Auth — DEV bypass (set true for local dev without Cognito)
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
NEXT_PUBLIC_DEV_TENANT_ID=seed-tenant-id

# Auth — Cognito (required for production; not needed when DEV_AUTH_BYPASS=true)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# App domain (used by middleware for subdomain tenant resolution)
NEXT_PUBLIC_APP_DOMAIN=vigilhq.com

# PWA (set true in Phase 2 to activate service worker)
NEXT_PUBLIC_ENABLE_PWA=false
